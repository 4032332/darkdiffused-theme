{% if section.settings.collection != blank %}
  {% assign featured = collections[section.settings.collection] %}
{% endif %}

<section class="section-pad bg-panel">
  <div class="container">
    <div class="eyebrow">{{ section.settings.eyebrow | default: 'Most Wanted' }}</div>
    <h2 class="display-md" style="margin-bottom: var(--space-lg);">
      {{ section.settings.heading | default: 'Best' }}<em class="brass">{{ section.settings.heading_em | default: 'sellers' }}</em>
    </h2>

    <div class="product-grid product-grid--4">
      {% if featured != blank %}
        {% for product in featured.products limit: section.settings.product_count %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        {% for product in collections.all.products limit: section.settings.product_count %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
      <div style="text-align: center; margin-top: var(--space-xl);">
        <a href="{{ section.settings.cta_url }}" class="btn-ghost">{{ section.settings.cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Most Wanted"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best"
    },
    {
      "type": "text",
      "id": "heading_em",
      "label": "Heading emphasis",
      "default": "sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to feature"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
