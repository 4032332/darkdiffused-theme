<style>
/* ── HERO — The Room ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 12vh;
  overflow: hidden;
  background-color: #060402;
  background-image:
    linear-gradient(180deg,
      rgba(2,1,0,0.55) 0%,
      rgba(4,2,1,0.35) 35%,
      rgba(6,3,1,0.5)  70%,
      rgba(2,1,0,0.75) 100%
    ),
    url({{ 'hero-bg.jpg' | asset_url }});
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
}

/* ── FILAMENT BULB ── */
.hero__bulb-wrap {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  pointer-events: none;
}

.hero__bulb-svg {
  display: block;
  margin: 0 auto;
  overflow: visible;
}

.hero__bulb-filaments {
  animation: heroFilFlicker 3.5s ease-in-out 0.8s infinite;
}

@keyframes heroFilFlicker {
  0%, 100% { opacity: 1;    filter: brightness(1); }
  18%       { opacity: 0.82; filter: brightness(0.88); }
  35%       { opacity: 1;    filter: brightness(1.06); }
  60%       { opacity: 0.9;  filter: brightness(0.94); }
  78%       { opacity: 1;    filter: brightness(1.02); }
}

/* Radial light pool cast by bulb */
.hero__light-pool {
  position: absolute;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  width: 900px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(ellipse at 50% 0%,
    rgba(255,154,46,0.14) 0%,
    rgba(200,133,26,0.07) 30%,
    rgba(139,105,20,0.03) 55%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 2;
  animation: lightBreathe 6s ease-in-out infinite;
}

@keyframes lightBreathe {
  0%, 100% { opacity: 1; }
  15%       { opacity: 0.88; }
  30%       { opacity: 1; }
  72%       { opacity: 0.92; }
}


/* ── CONTENT ── */
.hero__content {
  position: relative;
  z-index: 4;
  text-align: center;
  padding: 0 var(--gutter);
  max-width: 880px;
  margin-top: 0;
}

.hero__eyebrow {
  font-family: var(--font-ui);
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--brass-mid, #8A6828);
  margin-bottom: var(--space-md);
}

.hero__headline {
  margin-bottom: var(--space-md);
  line-height: 1.05;
}

.hero__h1-top {
  font-family: var(--font-display);
  font-size: clamp(56px, 9vw, 120px);
  font-weight: 700;
  color: #D4B896;
  letter-spacing: -0.01em;
  display: block;
  text-shadow:
    0 2px 40px rgba(255,154,46,0.25),
    0 0 80px rgba(255,154,46,0.1);
}

.hero__h1-em {
  font-family: var(--font-display);
  font-size: clamp(58px, 9.5vw, 126px);
  font-weight: 700;
  font-style: italic;
  color: #FF9A2E;
  display: block;
  text-shadow:
    0 0 40px rgba(255,154,46,0.5),
    0 0 80px rgba(255,154,46,0.25),
    0 2px 4px rgba(0,0,0,0.8);
}

.hero__sub {
  font-family: var(--font-body);
  font-size: clamp(16px, 1.4vw, 20px);
  font-style: italic;
  color: #D4B896;
  opacity: 0.75;
  max-width: 540px;
  margin: 0 auto var(--space-lg);
  line-height: 1.6;
}

.hero__btns {
  display: flex;
  gap: var(--space-sm);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

/* ── BAR TOP ── */
.hero__bar-top {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 4;
}

.hero__bar-surface {
  height: 56px;
  background:
    repeating-linear-gradient(
      90.3deg,
      transparent 0px, transparent 10px,
      rgba(60,35,10,0.15) 10px, rgba(60,35,10,0.15) 11px
    ),
    repeating-linear-gradient(
      89.8deg,
      transparent 0px, transparent 35px,
      rgba(40,22,6,0.2) 35px, rgba(40,22,6,0.2) 36px
    ),
    linear-gradient(180deg,
      #2A1A08 0%,
      #1A0E04 40%,
      #120A02 100%
    );
  border-top: 1px solid rgba(200,133,26,0.15);
  box-shadow:
    0 -1px 0 rgba(255,154,46,0.06),
    inset 0 1px 0 rgba(255,200,100,0.08),
    0 -20px 60px rgba(0,0,0,0.6);
  position: relative;
}

/* Brass rail — the polished strip along the bar top */
.hero__bar-rail {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5px;
  background: linear-gradient(90deg,
    #8B6914 0%,
    #C8851A 8%,
    #FF9A2E 20%,
    #E8CC78 30%,
    #D4AE50 40%,
    #C8851A 50%,
    #E8CC78 62%,
    #D4AE50 72%,
    #C8851A 85%,
    #8B6914 100%
  );
  box-shadow:
    0 0 12px rgba(255,154,46,0.4),
    0 2px 8px rgba(0,0,0,0.6);
}

/* Range nav in bar surface */
.hero__range-nav {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xl);
}

.hero__range-link {
  font-family: var(--font-ui);
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--fog, #A89878);
  text-decoration: none;
  transition: color 0.3s;
  position: relative;
}
.hero__range-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0; right: 0;
  height: 1px;
  background: #FF9A2E;
  transform: scaleX(0);
  transition: transform 0.3s ease;
}
.hero__range-link:hover { color: #FF9A2E; }
.hero__range-link:hover::after { transform: scaleX(1); }

/* Range link accent colours */
.hero__range-link--i   { --accent: #D4AE50; }
.hero__range-link--ii  { --accent: #B87333; }
.hero__range-link--iii { --accent: #C8B8A8; }
.hero__range-link--i:hover   { color: #D4AE50; }
.hero__range-link--ii:hover  { color: #B87333; }
.hero__range-link--iii:hover { color: #C8B8A8; }
.hero__range-link--i:hover::after   { background: #D4AE50; }
.hero__range-link--ii:hover::after  { background: #B87333; }
.hero__range-link--iii:hover::after { background: #C8B8A8; }

@media (max-width: 700px) {
  .hero__content { padding: 0 var(--gutter-sm); }
  .hero::before, .hero::after { left: var(--gutter-sm); right: var(--gutter-sm); }
  .hero__light-pool { width: 100vw; }
  .hero__range-nav { gap: var(--space-md); }
}
</style>

<section class="hero" aria-labelledby="hero-heading">

  <!-- Edison filament bulb — SVG -->
  <div class="hero__bulb-wrap" aria-hidden="true">
    <svg class="hero__bulb-svg" viewBox="0 0 80 270" width="80" height="270" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <!-- Globe radial fill: white-hot centre → amber → dark edge -->
        <radialGradient id="hbg" cx="38%" cy="36%" r="58%" fx="38%" fy="36%">
          <stop offset="0%"   stop-color="#FFF9F0" stop-opacity="0.92"/>
          <stop offset="22%"  stop-color="#FFE8A8" stop-opacity="0.82"/>
          <stop offset="50%"  stop-color="#FF9A2E" stop-opacity="0.65"/>
          <stop offset="78%"  stop-color="#C8851A" stop-opacity="0.45"/>
          <stop offset="100%" stop-color="#8B5E10" stop-opacity="0.2"/>
        </radialGradient>
        <!-- Specular highlight -->
        <radialGradient id="hbs" cx="28%" cy="26%" r="28%">
          <stop offset="0%"   stop-color="white" stop-opacity="0.38"/>
          <stop offset="100%" stop-color="white" stop-opacity="0"/>
        </radialGradient>
        <!-- Knurled socket brass gradient -->
        <linearGradient id="hsg" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%"   stop-color="#4A3008"/>
          <stop offset="18%"  stop-color="#8A6018"/>
          <stop offset="44%"  stop-color="#C8A030"/>
          <stop offset="58%"  stop-color="#D4AE50"/>
          <stop offset="78%"  stop-color="#9A7020"/>
          <stop offset="100%" stop-color="#4A3008"/>
        </linearGradient>
        <!-- Filament wire glow blur -->
        <filter id="fg" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur stdDeviation="2.8" result="b"/>
          <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <!-- Outer bulb glow blur -->
        <filter id="og" x="-150%" y="-150%" width="400%" height="400%">
          <feGaussianBlur stdDeviation="10"/>
        </filter>
      </defs>

      <!-- Outer glow halo around globe -->
      <path d="M28 112 C22 120,11 136,11 158 C11 180,22 196,40 202 C58 196,69 180,69 158 C69 136,58 120,52 112 Z"
            fill="#FF9A2E" opacity="0.22" filter="url(#og)"/>

      <!-- Ceiling rose -->
      <ellipse cx="40" cy="5" rx="14" ry="4"   fill="#1C1208" stroke="#7A5818" stroke-width="0.6"/>
      <ellipse cx="40" cy="5" rx="10" ry="2.5"  fill="none"    stroke="#5A4010" stroke-width="0.4"/>

      <!-- Twisted fabric cord (two interleaving sine paths) -->
      <path d="M40 9 C37 17,43 25,40 33 C37 41,43 49,40 57 C37 65,43 73,40 78"
            stroke="#3A2008" stroke-width="1.4" fill="none"/>
      <path d="M40 9 C43 17,37 25,40 33 C43 41,37 49,40 57 C43 65,37 73,40 78"
            stroke="#6A4018" stroke-width="0.6" fill="none" opacity="0.7"/>

      <!-- Knurled brass socket -->
      <rect x="28" y="78" width="24" height="36" rx="1" fill="url(#hsg)"/>
      <!-- 5 knurl shadow rings -->
      <line x1="28" y1="83"  x2="52" y2="83"  stroke="#1E1006" stroke-width="0.9" opacity="0.65"/>
      <line x1="28" y1="88"  x2="52" y2="88"  stroke="#1E1006" stroke-width="0.9" opacity="0.65"/>
      <line x1="28" y1="93"  x2="52" y2="93"  stroke="#1E1006" stroke-width="0.9" opacity="0.65"/>
      <line x1="28" y1="98"  x2="52" y2="98"  stroke="#1E1006" stroke-width="0.9" opacity="0.65"/>
      <line x1="28" y1="103" x2="52" y2="103" stroke="#1E1006" stroke-width="0.9" opacity="0.65"/>
      <!-- Knurl highlight flashes -->
      <line x1="29" y1="82"  x2="51" y2="82"  stroke="#D4AE50" stroke-width="0.3" opacity="0.35"/>
      <line x1="29" y1="87"  x2="51" y2="87"  stroke="#D4AE50" stroke-width="0.3" opacity="0.35"/>
      <line x1="29" y1="92"  x2="51" y2="92"  stroke="#D4AE50" stroke-width="0.3" opacity="0.35"/>
      <line x1="29" y1="97"  x2="51" y2="97"  stroke="#D4AE50" stroke-width="0.3" opacity="0.35"/>
      <line x1="29" y1="102" x2="51" y2="102" stroke="#D4AE50" stroke-width="0.3" opacity="0.35"/>
      <!-- Set screw -->
      <circle cx="52" cy="90" r="1.5" fill="#1A1008" stroke="#8A6018" stroke-width="0.4"/>
      <line x1="50.9" y1="90" x2="53.1" y2="90" stroke="#5A4010" stroke-width="0.4"/>

      <!-- Glass globe -->
      <path d="M28 112 C22 120,11 136,11 158 C11 180,22 196,40 202 C58 196,69 180,69 158 C69 136,58 120,52 112 Z"
            fill="url(#hbg)" stroke="rgba(255,220,140,0.22)" stroke-width="0.6"/>
      <!-- Specular -->
      <path d="M28 112 C22 120,11 136,11 158 C11 180,22 196,40 202 C58 196,69 180,69 158 C69 136,58 120,52 112 Z"
            fill="url(#hbs)" stroke="none"/>

      <!-- Squirrel-cage filament — animated group -->
      <g class="hero__bulb-filaments">
        <!-- Support stems -->
        <line x1="40" y1="112" x2="40" y2="130" stroke="#9A7020" stroke-width="0.8" opacity="0.55"/>
        <line x1="40" y1="188" x2="40" y2="200" stroke="#9A7020" stroke-width="0.7" opacity="0.4"/>

        <!-- Glow layer: wide amber strokes with blur -->
        <g filter="url(#fg)" opacity="0.55">
          <path d="M40 188 C40 170,21 150,21 130" stroke="#FF8020" stroke-width="5"   fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,26 150,26 130" stroke="#FFA030" stroke-width="4"   fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,31 150,31 130" stroke="#FFB840" stroke-width="4"   fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,35 150,35 130" stroke="#FFD060" stroke-width="3.5" fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,40 150,40 130" stroke="#FFEECC" stroke-width="5"   fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,45 150,45 130" stroke="#FFD060" stroke-width="3.5" fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,49 150,49 130" stroke="#FFB840" stroke-width="4"   fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,54 150,54 130" stroke="#FFA030" stroke-width="4"   fill="none" stroke-linecap="round"/>
          <path d="M40 188 C40 170,59 150,59 130" stroke="#FF8020" stroke-width="5"   fill="none" stroke-linecap="round"/>
          <!-- Top bar glow -->
          <line x1="21" y1="130" x2="59" y2="130" stroke="#FFD060" stroke-width="3" stroke-linecap="round"/>
        </g>

        <!-- Crisp wire layer -->
        <g opacity="0.92">
          <path d="M40 188 C40 170,21 150,21 130" stroke="#FFFCE8" stroke-width="0.55" fill="none"/>
          <path d="M40 188 C40 170,26 150,26 130" stroke="#FFFCE8" stroke-width="0.5"  fill="none"/>
          <path d="M40 188 C40 170,31 150,31 130" stroke="#FFFCE8" stroke-width="0.5"  fill="none"/>
          <path d="M40 188 C40 170,35 150,35 130" stroke="#FFFCE8" stroke-width="0.5"  fill="none"/>
          <path d="M40 188 C40 170,40 150,40 130" stroke="white"   stroke-width="0.65" fill="none"/>
          <path d="M40 188 C40 170,45 150,45 130" stroke="#FFFCE8" stroke-width="0.5"  fill="none"/>
          <path d="M40 188 C40 170,49 150,49 130" stroke="#FFFCE8" stroke-width="0.5"  fill="none"/>
          <path d="M40 188 C40 170,54 150,54 130" stroke="#FFFCE8" stroke-width="0.5"  fill="none"/>
          <path d="M40 188 C40 170,59 150,59 130" stroke="#FFFCE8" stroke-width="0.55" fill="none"/>
          <!-- Top horizontal bus bar -->
          <line x1="21" y1="130" x2="59" y2="130" stroke="#FFE890" stroke-width="0.6"/>
          <!-- Cross wire -->
          <line x1="26" y1="162" x2="54" y2="162" stroke="#FFE890" stroke-width="0.4" opacity="0.65"/>
        </g>
      </g>
    </svg>
  </div>

  <!-- Light pool radiated downward -->
  <div class="hero__light-pool" aria-hidden="true"></div>

  <!-- Main content — emerges from darkness -->
  <div class="hero__content">
    <p class="hero__eyebrow">{{ section.settings.eyebrow | default: 'Est. 2025 · Australia' }}</p>

    <div class="hero__headline">
      <span class="hero__h1-top" id="hero-heading">{{ section.settings.heading | default: 'Own the' }}</span>
      <em class="hero__h1-em">{{ section.settings.heading_em | default: 'atmosphere.' }}</em>
    </div>

    <p class="hero__sub">
      {{ section.settings.subheading | default: 'Premium diffusers for men who understand that the right scent is the quietest power move in any room.' }}
    </p>

    <div class="hero__btns">
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn-brass">
        {{ section.settings.cta_label | default: 'Enter the Bar' }}
      </a>
      {% if section.settings.secondary_url != blank %}
        <a href="{{ section.settings.secondary_url }}" class="btn-ghost">
          {{ section.settings.secondary_label | default: 'Our Ranges' }}
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Bar top with brass rail and range navigation -->
  <div class="hero__bar-top" aria-hidden="true">
    <div class="hero__bar-surface">
      <div class="hero__bar-rail"></div>
      <nav class="hero__range-nav" aria-label="Range navigation">
        <a href="/collections/the-elevated-man-1" class="hero__range-link hero__range-link--i">I — The Elevated Man</a>
        <a href="/collections/man-child" class="hero__range-link hero__range-link--ii">II — The Man Child</a>
        <a href="/collections/happy-wife-happy-life-1" class="hero__range-link hero__range-link--iii">III — Happy Wife, Happy Life</a>
      </nav>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",        "label": "Eyebrow",              "default": "Est. 2025 · Australia" },
    { "type": "text",     "id": "heading",         "label": "Heading first line",   "default": "Own the" },
    { "type": "text",     "id": "heading_em",      "label": "Heading italic amber", "default": "atmosphere." },
    { "type": "textarea", "id": "subheading",      "label": "Subheading",           "default": "Premium diffusers for men who understand that the right scent is the quietest power move in any room." },
    { "type": "text",     "id": "cta_label",       "label": "Primary button",       "default": "Enter the Bar" },
    { "type": "url",      "id": "cta_url",         "label": "Primary button URL" },
    { "type": "text",     "id": "secondary_label", "label": "Secondary button",     "default": "Our Ranges" },
    { "type": "url",      "id": "secondary_url",   "label": "Secondary button URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
