<style>
/* ── HERO — The Room ── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background-color: #060402;
  background-image:
    repeating-linear-gradient(
      90.5deg,
      transparent 0px, transparent 8px,
      rgba(60,35,10,0.08) 8px, rgba(60,35,10,0.08) 9px
    ),
    repeating-linear-gradient(
      89.2deg,
      transparent 0px, transparent 28px,
      rgba(40,22,6,0.12) 28px, rgba(40,22,6,0.12) 29px
    ),
    linear-gradient(180deg,
      #060402 0%,
      #0E0804 20%,
      #100A04 55%,
      #0A0602 80%,
      #060402 100%
    );
}

/* Wainscoting — dark walnut panels on left and right walls */
.hero::before {
  content: '';
  position: absolute;
  top: var(--space-xl); bottom: 80px;
  left: var(--gutter); right: var(--gutter);
  border: 1px solid rgba(200,133,26,0.08);
  pointer-events: none;
  z-index: 2;
}
.hero::after {
  content: '';
  position: absolute;
  top: calc(var(--space-xl) + 10px); bottom: 90px;
  left: calc(var(--gutter) + 10px); right: calc(var(--gutter) + 10px);
  border: 1px solid rgba(200,133,26,0.04);
  pointer-events: none;
  z-index: 2;
}

/* ── FILAMENT BULB ── */
.hero__bulb-wrap {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  pointer-events: none;
}

.hero__cord {
  width: 1px;
  height: 120px;
  background: linear-gradient(to bottom, rgba(80,50,10,0.0), rgba(200,133,26,0.5));
  margin: 0 auto;
}

.hero__bulb {
  width: 32px;
  height: 40px;
  border-radius: 50% 50% 45% 45%;
  background: radial-gradient(ellipse at 40% 35%,
    #FFF8E8 0%,
    #FFDF80 20%,
    #FF9A2E 50%,
    #C8851A 80%,
    #8B6914 100%
  );
  box-shadow:
    0 0 8px rgba(255,154,46,0.9),
    0 0 24px rgba(255,154,46,0.6),
    0 0 60px rgba(255,154,46,0.35),
    0 0 120px rgba(255,154,46,0.15);
  margin: 0 auto;
  animation: filamentFlicker 6s ease-in-out infinite;
  position: relative;
}

/* Bulb base cap */
.hero__bulb::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 50%;
  transform: translateX(-50%);
  width: 20px;
  height: 10px;
  background: linear-gradient(180deg, var(--brass-mid, #8A6828), var(--brass-dark, #5A4018));
  border-radius: 0 0 4px 4px;
}

@keyframes filamentFlicker {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(255,154,46,0.9), 0 0 24px rgba(255,154,46,0.6), 0 0 60px rgba(255,154,46,0.35), 0 0 120px rgba(255,154,46,0.15); }
  15%       { opacity: 0.94; box-shadow: 0 0 6px rgba(255,154,46,0.8), 0 0 18px rgba(255,154,46,0.5), 0 0 48px rgba(255,154,46,0.28), 0 0 100px rgba(255,154,46,0.12); }
  30%       { opacity: 1; }
  72%       { opacity: 0.96; box-shadow: 0 0 7px rgba(255,154,46,0.85), 0 0 20px rgba(255,154,46,0.55), 0 0 52px rgba(255,154,46,0.3), 0 0 110px rgba(255,154,46,0.13); }
  85%       { opacity: 1; }
}

/* Radial light pool cast by bulb */
.hero__light-pool {
  position: absolute;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  width: 900px;
  height: 700px;
  border-radius: 50%;
  background: radial-gradient(ellipse at 50% 0%,
    rgba(255,154,46,0.14) 0%,
    rgba(200,133,26,0.07) 30%,
    rgba(139,105,20,0.03) 55%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 2;
  animation: lightBreathe 6s ease-in-out infinite;
}

@keyframes lightBreathe {
  0%, 100% { opacity: 1; }
  15%       { opacity: 0.88; }
  30%       { opacity: 1; }
  72%       { opacity: 0.92; }
}

/* Side wall lanterns */
.hero__lantern {
  position: absolute;
  top: 30%;
  width: 200px;
  height: 300px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 2;
  background: radial-gradient(ellipse,
    rgba(255,154,46,0.07) 0%,
    rgba(200,133,26,0.03) 40%,
    transparent 70%
  );
  filter: blur(12px);
}
.hero__lantern--left  { left: -40px; }
.hero__lantern--right { right: -40px; }

/* ── CONTENT ── */
.hero__content {
  position: relative;
  z-index: 4;
  text-align: center;
  padding: 0 var(--gutter);
  max-width: 880px;
  margin-top: 60px;
}

.hero__eyebrow {
  font-family: var(--font-ui);
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--brass-mid, #8A6828);
  margin-bottom: var(--space-md);
}

.hero__headline {
  margin-bottom: var(--space-md);
  line-height: 1.05;
}

.hero__h1-top {
  font-family: var(--font-display);
  font-size: clamp(56px, 9vw, 120px);
  font-weight: 700;
  color: #D4B896;
  letter-spacing: -0.01em;
  display: block;
  text-shadow:
    0 2px 40px rgba(255,154,46,0.25),
    0 0 80px rgba(255,154,46,0.1);
}

.hero__h1-em {
  font-family: var(--font-display);
  font-size: clamp(58px, 9.5vw, 126px);
  font-weight: 700;
  font-style: italic;
  color: #FF9A2E;
  display: block;
  text-shadow:
    0 0 40px rgba(255,154,46,0.5),
    0 0 80px rgba(255,154,46,0.25),
    0 2px 4px rgba(0,0,0,0.8);
}

.hero__sub {
  font-family: var(--font-body);
  font-size: clamp(16px, 1.4vw, 20px);
  font-style: italic;
  color: #D4B896;
  opacity: 0.75;
  max-width: 540px;
  margin: 0 auto var(--space-lg);
  line-height: 1.6;
}

.hero__btns {
  display: flex;
  gap: var(--space-sm);
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: var(--space-xl);
}

/* ── BAR TOP ── */
.hero__bar-top {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 4;
}

.hero__bar-surface {
  height: 56px;
  background:
    repeating-linear-gradient(
      90.3deg,
      transparent 0px, transparent 10px,
      rgba(60,35,10,0.15) 10px, rgba(60,35,10,0.15) 11px
    ),
    repeating-linear-gradient(
      89.8deg,
      transparent 0px, transparent 35px,
      rgba(40,22,6,0.2) 35px, rgba(40,22,6,0.2) 36px
    ),
    linear-gradient(180deg,
      #2A1A08 0%,
      #1A0E04 40%,
      #120A02 100%
    );
  border-top: 1px solid rgba(200,133,26,0.15);
  box-shadow:
    0 -1px 0 rgba(255,154,46,0.06),
    inset 0 1px 0 rgba(255,200,100,0.08),
    0 -20px 60px rgba(0,0,0,0.6);
  position: relative;
}

/* Brass rail — the polished strip along the bar top */
.hero__bar-rail {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 5px;
  background: linear-gradient(90deg,
    #8B6914 0%,
    #C8851A 8%,
    #FF9A2E 20%,
    #E8CC78 30%,
    #D4AE50 40%,
    #C8851A 50%,
    #E8CC78 62%,
    #D4AE50 72%,
    #C8851A 85%,
    #8B6914 100%
  );
  box-shadow:
    0 0 12px rgba(255,154,46,0.4),
    0 2px 8px rgba(0,0,0,0.6);
}

/* Range nav in bar surface */
.hero__range-nav {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xl);
}

.hero__range-link {
  font-family: var(--font-ui);
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--fog, #A89878);
  text-decoration: none;
  transition: color 0.3s;
  position: relative;
}
.hero__range-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0; right: 0;
  height: 1px;
  background: #FF9A2E;
  transform: scaleX(0);
  transition: transform 0.3s ease;
}
.hero__range-link:hover { color: #FF9A2E; }
.hero__range-link:hover::after { transform: scaleX(1); }

/* Range link accent colours */
.hero__range-link--i   { --accent: #D4AE50; }
.hero__range-link--ii  { --accent: #B87333; }
.hero__range-link--iii { --accent: #C8B8A8; }
.hero__range-link--i:hover   { color: #D4AE50; }
.hero__range-link--ii:hover  { color: #B87333; }
.hero__range-link--iii:hover { color: #C8B8A8; }
.hero__range-link--i:hover::after   { background: #D4AE50; }
.hero__range-link--ii:hover::after  { background: #B87333; }
.hero__range-link--iii:hover::after { background: #C8B8A8; }

@media (max-width: 700px) {
  .hero__content { margin-top: 100px; padding: 0 var(--gutter-sm); }
  .hero::before, .hero::after { left: var(--gutter-sm); right: var(--gutter-sm); }
  .hero__light-pool { width: 100vw; }
  .hero__range-nav { gap: var(--space-md); }
}
</style>

<section class="hero" aria-labelledby="hero-heading">

  <!-- Filament bulb -->
  <div class="hero__bulb-wrap" aria-hidden="true">
    <div class="hero__cord"></div>
    <div class="hero__bulb"></div>
  </div>

  <!-- Light pool radiated downward -->
  <div class="hero__light-pool" aria-hidden="true"></div>

  <!-- Side wall lanterns -->
  <div class="hero__lantern hero__lantern--left"  aria-hidden="true"></div>
  <div class="hero__lantern hero__lantern--right" aria-hidden="true"></div>

  <!-- Main content — emerges from darkness -->
  <div class="hero__content">
    <p class="hero__eyebrow">{{ section.settings.eyebrow | default: 'Est. 2025 · Australia' }}</p>

    <div class="hero__headline">
      <span class="hero__h1-top" id="hero-heading">{{ section.settings.heading | default: 'Own the' }}</span>
      <em class="hero__h1-em">{{ section.settings.heading_em | default: 'atmosphere.' }}</em>
    </div>

    <p class="hero__sub">
      {{ section.settings.subheading | default: 'Premium diffusers for men who understand that the right scent is the quietest power move in any room.' }}
    </p>

    <div class="hero__btns">
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn-brass">
        {{ section.settings.cta_label | default: 'Enter the Bar' }}
      </a>
      {% if section.settings.secondary_url != blank %}
        <a href="{{ section.settings.secondary_url }}" class="btn-ghost">
          {{ section.settings.secondary_label | default: 'Our Ranges' }}
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Bar top with brass rail and range navigation -->
  <div class="hero__bar-top" aria-hidden="true">
    <div class="hero__bar-surface">
      <div class="hero__bar-rail"></div>
      <nav class="hero__range-nav" aria-label="Range navigation">
        <a href="/collections/the-elevated-man-1" class="hero__range-link hero__range-link--i">I — The Elevated Man</a>
        <a href="/collections/man-child" class="hero__range-link hero__range-link--ii">II — The Man Child</a>
        <a href="/collections/happy-wife-happy-life-1" class="hero__range-link hero__range-link--iii">III — Happy Wife, Happy Life</a>
      </nav>
    </div>
  </div>

</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",        "label": "Eyebrow",              "default": "Est. 2025 · Australia" },
    { "type": "text",     "id": "heading",         "label": "Heading first line",   "default": "Own the" },
    { "type": "text",     "id": "heading_em",      "label": "Heading italic amber", "default": "atmosphere." },
    { "type": "textarea", "id": "subheading",      "label": "Subheading",           "default": "Premium diffusers for men who understand that the right scent is the quietest power move in any room." },
    { "type": "text",     "id": "cta_label",       "label": "Primary button",       "default": "Enter the Bar" },
    { "type": "url",      "id": "cta_url",         "label": "Primary button URL" },
    { "type": "text",     "id": "secondary_label", "label": "Secondary button",     "default": "Our Ranges" },
    { "type": "url",      "id": "secondary_url",   "label": "Secondary button URL" }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
