{% assign current_variant = product.selected_or_first_available_variant %}

{% assign range_colour = 'var(--range1)' %}
{% assign range_label = '' %}
{% for tag in product.tags %}
  {% if tag == 'range-2' or tag == 'man-child' %}
    {% assign range_colour = 'var(--range2)' %}
  {% elsif tag == 'range-3' or tag == 'happy-wife' %}
    {% assign range_colour = 'var(--range3)' %}
  {% endif %}
  {% if tag contains 'range:' %}
    {% assign range_label = tag | remove: 'range:' | strip %}
  {% endif %}
{% endfor %}

<div class="breadcrumb">
  <span><a href="/">Home</a></span>
  {% if product.collections.first %}
    <span><a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a></span>
  {% endif %}
  <span>{{ product.title }}</span>
</div>

<div class="product-page">

  <!-- Gallery -->
  <div class="product-page__gallery">
    <div class="product-page__gallery-main">
      {% if product.featured_image != blank %}
        <img
          id="product-main-image"
          src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.featured_image.alt | escape | default: product.title }}"
          width="900"
          height="900"
          loading="eager"
        >
      {% else %}
        <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--panel);color:var(--muted);">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.8">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="m21 15-5-5L5 21"/>
          </svg>
        </div>
      {% endif %}
    </div>

    {% if product.images.size > 1 %}
      <div class="product-page__gallery-thumbs">
        {% for image in product.images %}
          <button class="product-page__thumb {% if forloop.first %}active{% endif %}"
                  onclick="document.getElementById('product-main-image').src='{{ image | image_url: width: 900 }}'; this.closest('.product-page__gallery-thumbs').querySelectorAll('.product-page__thumb').forEach(t => t.classList.remove('active')); this.classList.add('active');"
                  aria-label="View image {{ forloop.index }}">
            <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape }}" width="80" height="80" loading="lazy">
          </button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Info -->
  <div class="product-page__info">
    {% if range_label != blank or product.type != blank %}
      <span class="product-page__range-tag" style="color: {{ range_colour }}">
        {{ range_label | default: product.type }}
      </span>
    {% endif %}

    <h1 class="product-page__title">{{ product.title }}</h1>

    <div class="product-page__price">
      {% if current_variant.compare_at_price > current_variant.price %}
        <s style="color: var(--stone); font-size: 18px; margin-right: 10px;">{{ current_variant.compare_at_price | money }}</s>
      {% endif %}
      <span id="product-price">{{ current_variant.price | money }}</span>
    </div>

    {% if product.description != blank %}
      <div class="product-page__description">{{ product.description }}</div>
    {% endif %}

    <!-- Spec table from tags -->
    {% assign has_specs = false %}
    {% for tag in product.tags %}
      {% if tag contains 'spec:' %}
        {% assign has_specs = true %}
      {% endif %}
    {% endfor %}

    {% if has_specs %}
      <div class="product-page__specs">
        {% for tag in product.tags %}
          {% if tag contains 'spec:' %}
            {% assign spec_parts = tag | remove: 'spec:' | split: '|' %}
            <div class="product-page__spec">
              <span class="product-page__spec-label">{{ spec_parts[0] | strip }}</span>
              <span class="product-page__spec-value">{{ spec_parts[1] | strip }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <!-- Variants -->
    {% if product.variants.size > 1 %}
      <div style="margin-bottom: var(--space-md);">
        {% for option in product.options_with_values %}
          <div style="margin-bottom: var(--space-sm);">
            <label style="font-family: var(--font-ui); font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--stone); display: block; margin-bottom: 8px;">
              {{ option.name }}
            </label>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              {% for value in option.values %}
                <button onclick="selectOption({{ forloop.parentloop.index0 }}, '{{ value | escape }}')"
                        class="variant-btn {% if option.selected_value == value %}variant-btn--active{% endif %}"
                        data-option="{{ forloop.parentloop.index0 }}"
                        data-value="{{ value | escape }}"
                        style="
                          padding: 8px 16px;
                          font-family: var(--font-ui); font-size: 11px; letter-spacing: 0.1em;
                          {% if option.selected_value == value %}border: 1px solid var(--brass-light); color: var(--brass-light);{% else %}border: 1px solid rgba(212,174,80,0.2); color: var(--fog);{% endif %}
                          background: transparent; cursor: pointer; transition: all 0.3s;
                        ">
                  {{ value }}
                </button>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    <form class="product-form" action="/cart/add" method="post">
      <input type="hidden" name="id" id="variant-id" value="{{ current_variant.id }}">

      <div class="product-form__qty">
        <button type="button" data-action="decrement" aria-label="Decrease quantity">−</button>
        <input type="number" name="quantity" value="1" min="1" aria-label="Quantity">
        <button type="button" data-action="increment" aria-label="Increase quantity">+</button>
      </div>

      {% if current_variant.available %}
        <button type="submit" class="btn-brass product-form__submit">
          Add to Bag — {{ current_variant.price | money }}
        </button>
      {% else %}
        <button type="button" class="btn-brass product-form__submit" disabled style="opacity: 0.5; cursor: not-allowed;">
          Sold Out
        </button>
      {% endif %}
    </form>

    <!-- Selling points -->
    <div style="margin-top: var(--space-lg); padding-top: var(--space-md); border-top: 1px solid rgba(212,174,80,0.08);">
      {% assign points = 'Free shipping over $120|30-day returns|Australia-wide delivery' | split: '|' %}
      {% for point in points %}
        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px; font-family: var(--font-ui); font-size: 11px; letter-spacing: 0.08em; color: var(--stone);">
          <span style="color: var(--brass); font-size: 14px;">✦</span>
          {{ point }}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  // Variant selection
  const variantData = {{ product.variants | json }};
  let selectedOptions = [
    {% for variant in product.variants %}
      {% if variant.id == current_variant.id %}
        {{ variant.options | json }},
      {% endif %}
    {% endfor %}
  ];
  if (selectedOptions.length === 0) selectedOptions = {{ current_variant.options | json }};

  function selectOption(index, value) {
    selectedOptions[index] = value;
    const match = variantData.find(v =>
      v.options.every((opt, i) => opt === selectedOptions[i])
    );
    if (match) {
      document.getElementById('variant-id').value = match.id;
      document.getElementById('product-price').textContent = formatMoney(match.price);
    }
    document.querySelectorAll('[data-option="' + index + '"]').forEach(btn => {
      const isActive = btn.dataset.value === value;
      btn.style.borderColor = isActive ? 'var(--brass-light)' : 'rgba(212,174,80,0.2)';
      btn.style.color = isActive ? 'var(--brass-light)' : 'var(--fog)';
    });
  }

  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }
</script>

{% schema %}
{
  "name": "Product",
  "settings": [],
  "presets": [{ "name": "Product" }]
}
{% endschema %}
