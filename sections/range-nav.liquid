      "label": "Description",
      "default": "Dark, sophisticated diffusers with scents that command attention. Oud, leather, cedarwood. For the man who curates his environment with the same precision he applies to everything else."
    },
    {
      "type": "text",
      "id": "range1_cta",
      "label": "CTA label",
      "default": "Enter Range I"
    },
    {
      "type": "url",
      "id": "range1_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Range II — The Man Child"
    },
    {
      "type": "text",
      "id": "range2_name",
      "label": "Name",
      "default": "The Man Child"
    },
    {
      "type": "text",
      "id": "range2_sub",
      "label": "Tagline",
      "default": "Keep it ridiculous."
    },
    {
      "type": "textarea",
      "id": "range2_desc",
      "label": "Description",
      "default": "Rocket ships, cannons, volcanoes, and armoured trains. Because adulting is entirely optional and your space should make you grin."
    },
    {
      "type": "text",
      "id": "range2_cta",
      "label": "CTA label",
      "default": "Enter Range II"
    },
    {
      "type": "url",
      "id": "range2_url",
      "label": "URL"
    },
    {
      "type": "header",
      "content": "Range III — Happy Wife, Happy Life"
    },
    {
      "type": "text",
      "id": "range3_name",
      "label": "Name",
      "default": "Happy Wife, Happy Life"
    },
    {
      "type": "text",
      "id": "range3_sub",
      "label": "Tagline",
      "default": "Choose your battles."
    },
    {
      "type": "textarea",
      "id": "range3_desc",
      "label": "Description",
      "default": "Gallery-worthy diffusers and neutral, sophisticated scents. The fragrance both of you actually want in the house — the compromise that doesn't feel like one."
    },
    {
      "type": "text",
      "id": "range3_cta",
      "label": "CTA label",
      "default": "Enter Range III"
    },
    {
      "type": "url",
      "id": "range3_url",
      "label": "URL"
    }
  ],
  "presets": [{ "name": "Range Navigation" }]
}
{% endschema %}
